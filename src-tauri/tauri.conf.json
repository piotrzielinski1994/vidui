{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VidUI",
  "version": "0.1.0",
  "identifier": "com.pzielinski.vidui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1432",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VidUI",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
